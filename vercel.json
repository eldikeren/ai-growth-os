{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "cd frontend && npm install && npm run build && cp public/*.html dist/",
  "installCommand": "npm install && cd backend && npm install",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.mjs" },
    { "source": "/onboarding/:token", "destination": "/onboarding.html" },
    { "source": "/setup/:token", "destination": "/setup.html" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ],
  "headers": [
    { "source": "/assets/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] }
  ],
  "crons": [
    { "path": "/api/cron/enqueue-scheduled", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/process-queue", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/health-check", "schedule": "0 */6 * * *" }
  ],
  "functions": {
    "api/index.mjs": { "maxDuration": 60 }
  }
}
